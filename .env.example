# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored. Anything you `export` in your shell takes precedence.

# Production: Anthropic Claude.
# ANTHROPIC_API_KEY=sk-ant-...

# Dev/test: OpenRouter (any OpenAI-compatible model).
# Uncomment to switch the LLM provider away from Anthropic:
# SCOUT_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# SCOUT_LLM_MODEL=inclusionai/ling-2.6-1t:free
